# OpenKeys runs fully client-side with NO environment variables required.
#
# The only optional setting enables the in-app Google Fonts browser (1500+ fonts).
# Without it, OpenKeys still works — it just falls back to the bundled fonts.
# Get a key at https://developers.google.com/fonts/docs/developer_api
#
# Copy this file to .env to use it. Never commit your .env.

# VITE_GOOGLE_FONTS_API_KEY=your_google_fonts_api_key_here
