{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "allowImportingTsExtensions": false,
    "outDir": "dist-lib/types",
    "rootDir": "src"
  },
  "include": [
    "src/lib",
    "src/core",
    "src/modules",
    "src/shared",
    "src/vite-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
